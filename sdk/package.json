{
  "name": "airlayer",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build:wasm": "bash scripts/build-wasm.sh wasm",
    "build:wasm:lookml": "bash scripts/build-wasm.sh 'wasm,foreign-lookml'",
    "build:wasm:all": "bash scripts/build-wasm.sh 'wasm,foreign'",
    "build": "tsup",
    "build:full": "npm run build:wasm && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.28.0",
    "idb-keyval": "^6.2.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
